# Supabase → Settings → API Keys → вкладка «Legacy anon, service_role» → anon public (eyJ...)
# Совпадает с SUPABASE_ANON_KEY на сервере. Publishable sb_... можно не использовать, если API ругается.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Продакшен: полный URL Node API (если не /api на том же хосте)
# VITE_API_BASE=https://api.example.com/api
