PORT=8787
# Несколько фронтов: через запятую (прод: https://gold-panel.web.app,https://gold-panel.firebaseapp.com)
CORS_ORIGIN=http://localhost:5173

SUPABASE_URL=https://xxxx.supabase.co

# Только legacy service_role (JWT, строка начинается с eyJ).
# Dashboard → Settings → API Keys → «Legacy anon, service_role» → service_role → Copy.
# Не использовать sb_secret_… — иначе auth.getUser не работает.
SUPABASE_SERVICE_ROLE_KEY=

PRICE_CACHE_TTL_SEC=180

# Источник курса золота: auto | moex | cbr
# auto — Мосбиржа (фьючерс GLDRUBF, руб/г), при сбое официальный курс ЦБ
# moex — только Мосбиржа
# cbr — только ЦБ (как раньше)
PRICE_SOURCE=auto

# Опционально: свой URL ISS (по умолчанию GLDRUBF на FORTS)
# MOEX_GOLD_ISS_URL=https://iss.moex.com/iss/engines/futures/markets/forts/securities/GLDRUBF.json
