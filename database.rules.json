{
  "rules": {
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && (!root.child('admins').exists() || !root.child('admins').hasChildren())"
      }
    },
    "userRoles": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || (auth.uid === $uid && (!root.child('admins').exists() || !root.child('admins').hasChildren())))"
      }
    },
    "app": {
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "cache": {
      "goldPrice": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    }
  }
}
